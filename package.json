  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/web-push": "^3.6.3",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}