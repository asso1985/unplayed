{
  "name": "unplayed",
  "version": "1.0.0",
  "description": "YouTube Music album listening reminder",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start-dev": "DATA_DIR=. npm run start",
    "cron": "node dist/scripts/sync-and-remind.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "node dist/scripts/migrate-json.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "node-cron": "^4.2.1",
    "typescript": "^5.5.2",
    "ulid": "^2.3.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.3",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
